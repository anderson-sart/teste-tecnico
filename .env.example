# Configuração do ambiente
# Copie para .env e ajuste conforme necessário

APP_NAME="Teste Técnico"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=softline_db
DB_USERNAME=softline_user
DB_PASSWORD=softline_pass

# JWT (autenticação stateless)
JWT_SECRET=alterar-para-chave-secreta-em-producao
JWT_EXPIRATION=86400
