{
    "name": "teste-tecnico/backend",
    "type": "project",
    "description": "Sistema de cadastro de produtos e clientes - PHP puro",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^11.51",
        "illuminate/pagination": "^11.51",
        "illuminate/validation": "^11.51",
        "jenssegers/blade": "^2.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        },
        "files": ["app/helpers.php"]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
