# Configuração do Backend
# Em produção estas variáveis vêm do docker-compose ou K8s secrets

APP_NAME="Teste Técnico"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=softline_db
DB_USERNAME=softline_user
DB_PASSWORD=softline_pass

# JWT (autenticação stateless - compatível com multi-pod K8s)
JWT_SECRET=alterar-para-chave-secreta-em-producao
JWT_EXPIRATION=86400
