APP_NAME="Softline Teste Técnico"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=softline_db
DB_USERNAME=softline_user
DB_PASSWORD=softline_pass

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRATION=86400
